# Required: Discord bot token
DISCORD_TOKEN=

# Required: Kokoro-FastAPI base URL (e.g. http://localhost:8880)
API_ENDPOINT=

# Optional: Kokoro-FastAPI API key (leave blank for local/unauthenticated setups)
API_KEY=

# Optional: Default voice for all guilds (e.g. af_heart, af_bella, bm_lewis)
TTS_VOICE=af_heart

# Optional: Default speech speed, between 0.25 and 4.0
TTS_SPEED=1.0

# Optional: Default language code — "auto" detects from voice prefix,
# or set explicitly: a=American English, b=British English, j=Japanese, z=Chinese
TTS_LANG=auto
